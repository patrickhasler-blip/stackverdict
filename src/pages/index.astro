---
import Base from '../layouts/Base.astro';
import Wizard from '../components/Wizard.jsx';
import { COMBOS } from '../data/combos.js';
const toolCount = new Set(COMBOS.map((c) => c.tool)).size;
---
<Base
  title="Subscription or API? The AI coding cost calculator for solo builders"
  description="Tell us what you're building and how much you actually use AI coding tools. We calculate whether a flat subscription or a raw API key is cheaper for you — no guessing, real numbers."
  canonical="https://stackverdict.dev/"
>
  <section class="hero">
    <div class="wrap hero-inner">
      <p class="eyebrow">The cost calculator for solo builders</p>
      <h1>Subscription or API?<br />We do the math.</h1>
      <p class="hero-lede">
        You've probably already shipped something with an AI tool — Lovable, Claude Code, one of
        the others. {toolCount} tools, dozens of tool-and-model pairings later, the question is
        which one is actually worth paying for. Tell us what you're building — a Shopify app, a
        mobile app, a directory — and roughly how many hours a day you're at the keyboard with
        these tools. We'll tell you straight whether a flat subscription or your own API key
        (the credential that bills you directly for what you use) works out cheaper.
      </p>
      <a class="btn btn-primary btn-lg" href="#find">Find my stack &rarr;</a>
    </div>
  </section>

  <section id="find" class="wrap section">
    <Wizard client:load />
  </section>

  <section id="how" class="wrap section">
    <h2 class="section-title">How it works</h2>
    <ol class="how-grid">
      <li>
        <span class="how-n">01</span>
        <h3>Pick your build</h3>
        <p>A Shopify app needs different tooling than a browser extension. We match on the product, not the hype.</p>
      </li>
      <li>
        <span class="how-n">02</span>
        <h3>Tell us your usage</h3>
        <p>Slide to roughly how many hours a day you're actually using these tools. That's what decides subscription vs. API — not a vague monthly guess.</p>
      </li>
      <li>
        <span class="how-n">03</span>
        <h3>See the real cost</h3>
        <p>Every match shows its estimated monthly cost and, where it applies, what the same usage would cost on raw API pricing instead.</p>
      </li>
    </ol>
  </section>

  <style>
    .hero { border-bottom: 2px solid var(--ink); background:
      repeating-linear-gradient(90deg, transparent 0 39px, rgba(20,27,46,.05) 39px 40px),
      repeating-linear-gradient(0deg, transparent 0 39px, rgba(20,27,46,.05) 39px 40px); }
    .hero-inner { padding: 72px 24px 64px; }
    .eyebrow { font-family: var(--display); font-weight: 600; font-size: 14px; letter-spacing: .08em; text-transform: uppercase; color: var(--verdict-deep); margin: 0 0 16px; }
    .hero h1 { font-size: clamp(38px, 7vw, 68px); font-weight: 700; margin: 0 0 20px; }
    .hero-lede { font-size: clamp(17px, 2.4vw, 21px); max-width: 620px; color: var(--ink-soft); margin: 0 0 28px; }
    .btn-lg { font-size: 17px; padding: 14px 26px; }
    .section { padding: 64px 24px 0; }
    .section-title { font-size: clamp(26px, 4vw, 36px); margin: 0 0 28px; }
    .how-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .how-grid li { border-top: 3px solid var(--ink); padding-top: 16px; }
    .how-n { font-family: var(--display); font-weight: 700; font-size: 14px; color: var(--verdict-deep); }
    .how-grid h3 { font-size: 20px; margin: 6px 0 8px; }
    .how-grid p { font-size: 15px; color: var(--slate); margin: 0; }
    @media (max-width: 720px) { .how-grid { grid-template-columns: 1fr; } }
  </style>
</Base>
