---
const { title, description, canonical } = Astro.props;
const site = 'StackVerdict';
// Only set in production (Vercel project env vars) — stays unset in local dev
// and preview builds, so no analytics script loads and nothing fires.
const goatcounterUrl = import.meta.env.PUBLIC_GOATCOUNTER_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · {site}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0F1B2D" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://stackverdict.dev/og-image.png" />
    <meta property="og:site_name" content={site} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://stackverdict.dev/og-image.png" />
    {goatcounterUrl && (
      // Cookie-free, no personal data, no consent banner needed — see /privacy.
      // GoatCounter is free for reasonable public use; self-host instead if
      // you outgrow that (https://www.goatcounter.com/help/host).
      <script data-goatcounter={goatcounterUrl} async src="https://gc.zgo.at/count.js"></script>
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --ink: #0F1B2D;
        --ink-soft: #26374F;
        --paper: #F4F2EC;
        --paper-dim: #E6E2D7;
        --verdict: #3FB984;       /* the recommendation / "pass" green */
        --verdict-deep: #1E8A5C;
        --ochre: #C99A3B;         /* restrained accent only */
        --slate: #5B6B85;
        --line: #D4CFC2;
        --ok: #1E8A5C;
        --warn: #B5562E;
        --radius: 4px;
        --display: 'Space Grotesk', system-ui, sans-serif;
        --body: 'Inter', system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: var(--body);
        background: var(--paper);
        color: var(--ink);
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
      }
      h1, h2, h3, legend { font-family: var(--display); line-height: 1.1; letter-spacing: -0.01em; }
      a { color: inherit; }
      .wrap { max-width: 1080px; margin: 0 auto; padding: 0 24px; }

      /* ---- header / footer ---- */
      .site-head {
        border-bottom: 2px solid var(--ink);
        background: var(--paper);
        position: sticky; top: 0; z-index: 20;
      }
      .site-head .wrap { display: flex; align-items: center; justify-content: space-between; height: 64px; }
      .brand { font-family: var(--display); font-weight: 700; font-size: 20px; text-decoration: none; letter-spacing: -0.02em; display: inline-flex; align-items: center; gap: 9px; }
      .brand-mark { flex-shrink: 0; }
      .brand span { color: var(--verdict-deep); }
      .nav { display: flex; gap: 22px; font-size: 15px; }
      .nav a { text-decoration: none; color: var(--ink-soft); font-weight: 500; }
      .nav a:hover { color: var(--ink); }
      .site-foot { border-top: 2px solid var(--ink); margin-top: 80px; padding: 32px 0; font-size: 14px; color: var(--slate); }
      .site-foot .wrap { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; }

      /* ---- buttons ---- */
      .btn {
        font-family: var(--display); font-weight: 600; font-size: 15px;
        border: 2px solid var(--ink); border-radius: var(--radius);
        padding: 10px 18px; cursor: pointer; text-decoration: none;
        display: inline-flex; align-items: center; gap: 6px;
        transition: transform .06s ease, box-shadow .06s ease;
      }
      .btn:active { transform: translateY(1px); }
      .btn-primary { background: var(--ink); color: var(--paper); box-shadow: 3px 3px 0 var(--verdict); }
      .btn-primary:hover { box-shadow: 4px 4px 0 var(--verdict); }
      .btn-primary:disabled { opacity: .4; cursor: not-allowed; box-shadow: none; }
      .btn-ghost { background: transparent; color: var(--ink); }
      .btn-ghost:hover { background: var(--paper-dim); }
      .btn-ghost:disabled { opacity: .35; cursor: not-allowed; }

      /* ---- wizard ---- */
      .wizard { background: #fff; border: 2px solid var(--ink); border-radius: var(--radius); box-shadow: 6px 6px 0 rgba(20,27,46,.12); }
      .wiz-progress {
        display: flex; list-style: none; margin: 0; padding: 0;
        border-bottom: 2px solid var(--ink); font-family: var(--display); font-size: 14px; font-weight: 600;
      }
      .wiz-progress li { flex: 1; display: flex; align-items: center; gap: 8px; justify-content: center; padding: 14px 8px; color: var(--slate); border-right: 1px solid var(--line); }
      .wiz-progress li:last-child { border-right: 0; }
      .wiz-progress li.is-active { color: var(--ink); background: var(--paper-dim); }
      .wiz-progress li.is-done { color: var(--verdict-deep); }
      .wiz-dot { display: inline-grid; place-items: center; width: 22px; height: 22px; border: 2px solid currentColor; border-radius: 50%; font-size: 12px; }

      .wiz-step { border: 0; margin: 0; padding: 28px; }
      .wiz-step legend { font-size: clamp(22px, 3vw, 30px); font-weight: 700; padding: 0 0 20px; }
      .opt-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
      .opt-grid-3 { grid-template-columns: repeat(3, 1fr); }
      .opt-grid-2 { grid-template-columns: repeat(2, 1fr); }
      .opt {
        text-align: left; background: var(--paper); border: 2px solid var(--line); border-radius: var(--radius);
        padding: 16px; cursor: pointer; display: flex; flex-direction: column; gap: 4px; transition: border-color .1s, background .1s;
      }
      .opt:hover { border-color: var(--ink-soft); }
      .opt.is-sel { border-color: var(--verdict-deep); background: #ECF6F0; box-shadow: inset 0 0 0 1px var(--verdict-deep); }
      .opt-title { font-family: var(--display); font-weight: 600; font-size: 16px; }
      .opt-blurb { font-size: 13px; color: var(--slate); }

      .wiz-nav { display: flex; justify-content: space-between; padding: 20px 28px; border-top: 2px solid var(--line); }

      /* ---- results ---- */
      .wiz-results { padding: 24px 28px 28px; }
      .wiz-results-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 8px; }
      .wiz-results-head h2 { font-size: 22px; }

      .rescard { border: 2px solid var(--line); border-radius: var(--radius); padding: 20px; margin-top: 16px; position: relative; background: var(--paper); }
      .rescard.is-top { border-color: var(--ink); box-shadow: 4px 4px 0 var(--verdict); }
      .rescard-flag {
        position: absolute; top: -13px; left: 18px; background: var(--verdict); color: var(--ink);
        font-family: var(--display); font-weight: 700; font-size: 12px; letter-spacing: .04em; text-transform: uppercase;
        padding: 3px 10px; border: 2px solid var(--ink); border-radius: 3px;
      }
      .rescard-main { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; }
      .rescard-id h3 { font-size: 22px; margin: 0; }
      .rescard-model { margin: 2px 0 0; font-size: 14px; color: var(--slate); }
      .rescard-price { text-align: right; flex-shrink: 0; }
      .rescard-price-val { font-family: var(--display); font-weight: 700; font-size: 22px; display: block; }
      .rescard-price-lab { font-size: 12px; color: var(--slate); text-transform: uppercase; letter-spacing: .04em; }

      .rescard-meters { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin: 18px 0; }
      .rescard-meters-single { grid-template-columns: 1fr; max-width: 280px; }
      .meter-head { display: flex; justify-content: space-between; font-size: 12px; font-family: var(--display); font-weight: 600; text-transform: uppercase; letter-spacing: .04em; margin-bottom: 5px; }
      .meter-val { color: var(--verdict-deep); }
      .meter-track { height: 7px; background: var(--paper-dim); border: 1px solid var(--line); border-radius: 20px; overflow: hidden; }
      .meter-fill { height: 100%; background: var(--ink); }

      .rescard-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 6px; }
      .rescard-pros, .rescard-cons { list-style: none; margin: 0; padding: 0; font-size: 14px; display: flex; flex-direction: column; gap: 5px; }
      .rescard-pros li::before { content: '+ '; color: var(--ok); font-weight: 700; }
      .rescard-cons li::before { content: '– '; color: var(--warn); font-weight: 700; }
      .rescard-notes { background: #ECF6F0; border-left: 3px solid var(--verdict-deep); padding: 10px 14px; margin: 12px 0; font-size: 13.5px; }
      .rescard-notes p { margin: 4px 0; }
      .rescard-foot { display: flex; gap: 10px; margin-top: 16px; }

      /* ---- email capture (fake door) ---- */
      .email-capture { border: 2px dashed var(--line); border-radius: var(--radius); padding: 20px; margin-top: 24px; background: var(--paper); }
      .email-capture h3 { font-size: 17px; margin: 0 0 6px; }
      .email-capture > form > p { font-size: 14px; color: var(--slate); margin: 0 0 14px; }
      .email-capture-row { display: flex; gap: 10px; flex-wrap: wrap; }
      .email-capture-row input[type="email"] {
        flex: 1; min-width: 220px; font: inherit; font-size: 15px;
        border: 2px solid var(--line); border-radius: var(--radius); padding: 10px 12px; background: #fff;
      }
      .email-capture-row input[type="email"]:focus { outline: none; border-color: var(--verdict-deep); }
      .email-capture-consent { display: flex; align-items: flex-start; gap: 8px; font-size: 12.5px; color: var(--slate); margin-top: 12px; }
      .email-capture-consent input { margin-top: 3px; }
      .email-capture-consent a { text-decoration: underline; }
      .email-capture-done { font-size: 15px; color: var(--verdict-deep); font-weight: 600; margin: 0; }

      /* ---- prose (guides) ---- */
      .prose { max-width: 720px; }
      .prose h1 { font-size: clamp(30px, 5vw, 44px); margin: 0 0 8px; }
      .prose h2 { font-size: 26px; margin: 40px 0 12px; padding-top: 8px; }
      .prose h3 { font-size: 19px; margin: 28px 0 8px; }
      .prose p, .prose li { font-size: 17px; }
      .prose .lede { font-size: 20px; color: var(--ink-soft); }
      .prose pre { background: var(--ink); color: #E8ECF5; padding: 16px 18px; border-radius: var(--radius); overflow-x: auto; font-size: 14px; line-height: 1.5; }
      .prose code { font-family: ui-monospace, 'SF Mono', Menlo, monospace; }
      .prose :not(pre) > code { background: var(--paper-dim); padding: 2px 6px; border-radius: 3px; font-size: .9em; }
      .prose .step { border-left: 3px solid var(--verdict); padding-left: 18px; margin: 24px 0; }
      .prose .callout { background: #fff; border: 2px solid var(--ink); border-radius: var(--radius); padding: 16px 18px; margin: 24px 0; box-shadow: 3px 3px 0 var(--verdict); }
      .breadcrumb { font-size: 14px; color: var(--slate); margin-bottom: 24px; }
      .breadcrumb a { text-decoration: none; }
      .guide-cta { margin-top: 48px; padding: 24px; border: 2px solid var(--ink); border-radius: var(--radius); background: #fff; }

      @media (max-width: 720px) {
        .opt-grid, .opt-grid-3, .opt-grid-2, .rescard-cols, .rescard-meters { grid-template-columns: 1fr; }
        .nav { display: none; }
        .wiz-progress li span:last-child { display: none; }
      }
      @media (prefers-reduced-motion: reduce) { * { transition: none !important; scroll-behavior: auto; } }
    </style>
  </head>
  <body>
    <header class="site-head">
      <div class="wrap">
        <a class="brand" href="/" aria-label="StackVerdict home">
          <svg class="brand-mark" width="30" height="30" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="2" y="2" width="36" height="36" rx="8" fill="#0F1B2D"/>
            <circle cx="20" cy="20" r="12.5" fill="none" stroke="#3FB984" stroke-width="1.4" stroke-dasharray="2.2 3.4" opacity="0.75"/>
            <path d="M13.8 20.2 L18 24.4 L26.6 14" stroke="#3FB984" stroke-width="3.1" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
          Stack<span>Verdict</span>
        </a>
        <nav class="nav">
          <a href="/#find">Find your stack</a>
          <a href="/guides/aider-setup">Guides</a>
          <a href="/#how">How it works</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-foot">
      <div class="wrap">
        <span>StackVerdict — the right AI coding stack, judged for your build.</span>
        <span>Prices and tools change fast. Verify before you buy. · <a href="/privacy">Privacy</a></span>
      </div>
    </footer>
  </body>
</html>
